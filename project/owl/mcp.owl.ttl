mcp:ToolChoiceModeEnum a owl:Class ;
    rdfs:label "ToolChoiceModeEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/mcp/ToolChoiceModeEnum#auto> <https://w3id.org/lmodel/mcp/ToolChoiceModeEnum#none> <https://w3id.org/lmodel/mcp/ToolChoiceModeEnum#required> ) ;
