    skos:definition "The server's preferences for model selection, requested of the client during sampling." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:NumberTypeEnum a owl:Class ;
    rdfs:label "NumberTypeEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/mcp/NumberTypeEnum#integer> <https://w3id.org/lmodel/mcp/NumberTypeEnum#number> ) ;
    skos:definition "Number type discriminator." ;
