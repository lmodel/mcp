            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:description ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:uri ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty mcp:uri ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:description ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:size ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:mimeType ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:description ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:size ],
        mcp:HasAnnotations,
        mcp:HasIcons,
        mcp:HasMeta,
        mcp:HasName ;
    skos:definition "A known resource that the server is capable of reading." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:ResourceTemplate a owl:Class ;
    rdfs:label "ResourceTemplate" ;
    rdfs:subClassOf [ a owl:Restriction ;
