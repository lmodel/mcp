@prefix dct: <http://purl.org/dc/terms/> .
@prefix linkml: <https://w3id.org/linkml/> .
@prefix mcp: <https://w3id.org/lmodel/mcp/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pav: <http://purl.org/pav/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/lmodel/mcp.owl.ttl> a owl:Ontology ;
    rdfs:label "mcp" ;
    dct:license "Apache-2.0" ;
    dct:source <https://github.com/modelcontextprotocol/modelcontextprotocol/tree/main/schema> ;
    dct:title "mcp" ;
    pav:version "draft" ;
    rdfs:seeAlso <https://lmodel.github.io/mcp>,
        <https://spec.modelcontextprotocol.io> ;
    skos:definition "Model Context Protocol LinkML Schema" .

mcp:AudioContent a owl:Class ;
    rdfs:label "AudioContent" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:mimeType ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:mimeType ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:mimeType ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:data ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:data ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:data ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                                owl:onDatatype xsd:string ;
                                owl:withRestrictions ( [ xsd:pattern "audio" ] ) ] ) ] ;
            owl:onProperty mcp:type ],
        mcp:HasAnnotations,
        mcp:HasMeta ;
    skos:definition "Audio provided to or from an LLM." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:BlobResourceContents a owl:Class ;
    rdfs:label "BlobResourceContents" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:blob ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty mcp:uri ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:uri ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:blob ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:mimeType ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:uri ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:blob ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:mimeType ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:mimeType ],
        mcp:HasMeta ;
    skos:definition "Blob resource contents." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:BooleanSchema a owl:Class ;
    rdfs:label "BooleanSchema" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:default ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:default_value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty mcp:default ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:title ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty mcp:default_value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:default ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:default_value ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                                owl:onDatatype xsd:string ;
                                owl:withRestrictions ( [ xsd:pattern "boolean" ] ) ] ) ] ;
            owl:onProperty mcp:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:title ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:description ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:title ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:description ] ;
    skos:definition "Boolean schema definition." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:CallToolRequest a owl:Class ;
    rdfs:label "CallToolRequest" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:method ],
        [ a owl:Restriction ;
            owl:allValuesFrom mcp:CallToolRequestParams ;
            owl:onProperty mcp:params ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:method ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "tools/call" ] ) ] ;
            owl:onProperty mcp:method ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:params ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:params ],
        mcp:JSONRPCRequest ;
    skos:definition "Used by the client to invoke a tool provided by the server." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:CallToolResultResponse a owl:Class ;
    rdfs:label "CallToolResultResponse" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom mcp:CallToolResult ;
            owl:onProperty mcp:result ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:result ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:result ],
        mcp:JSONRPCResultResponse ;
    skos:definition "A successful response from the server for a tools/call request." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:CancelTaskRequest a owl:Class ;
    rdfs:label "CancelTaskRequest" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:method ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "tasks/cancel" ] ) ] ;
            owl:onProperty mcp:method ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:method ],
        mcp:JSONRPCRequest ;
    skos:definition "A request to cancel a task." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:CancelTaskResultResponse a owl:Class ;
    rdfs:label "CancelTaskResultResponse" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:result ],
        [ a owl:Restriction ;
            owl:allValuesFrom mcp:CancelTaskResult ;
            owl:onProperty mcp:result ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:result ],
        mcp:JSONRPCResultResponse ;
    skos:definition "A successful response for a tasks/cancel request." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:CancelledNotification a owl:Class ;
    rdfs:label "CancelledNotification" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "notifications/cancelled" ] ) ] ;
            owl:onProperty mcp:method ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:method ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:params ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:method ],
        [ a owl:Restriction ;
            owl:allValuesFrom mcp:CancelledNotificationParams ;
            owl:onProperty mcp:params ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:params ],
        mcp:JSONRPCNotification ;
    skos:definition "Notification to indicate that a previously-issued request is being cancelled." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:ClientNotification a owl:Class ;
    rdfs:label "ClientNotification" ;
    skos:definition "A union of all notifications that can be sent by a client." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:ClientRequest a owl:Class ;
    rdfs:label "ClientRequest" ;
    skos:definition "A union of all requests that can be sent by a client." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:ClientResult a owl:Class ;
    rdfs:label "ClientResult" ;
    skos:definition "A union of all result types that a client can return." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:CompleteRequest a owl:Class ;
    rdfs:label "CompleteRequest" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:method ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:params ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:params ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:method ],
        [ a owl:Restriction ;
            owl:allValuesFrom mcp:CompleteRequestParams ;
            owl:onProperty mcp:params ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "completion/complete" ] ) ] ;
            owl:onProperty mcp:method ],
        mcp:JSONRPCRequest ;
    skos:definition "A request from the client to the server, to ask for completion options." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:CompleteResultResponse a owl:Class ;
    rdfs:label "CompleteResultResponse" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:result ],
        [ a owl:Restriction ;
            owl:allValuesFrom mcp:CompleteResult ;
            owl:onProperty mcp:result ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:result ],
        mcp:JSONRPCResultResponse ;
    skos:definition "A successful response from the server for a completion/complete request." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:ContentBlockVariants a owl:Class ;
    rdfs:label "ContentBlockVariants" ;
    skos:altLabel "ContentBlock" ;
    skos:definition "A union of all content block types. Maps to the vendor schema ContentBlock anyOf definition." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:CreateMessageRequest a owl:Class ;
    rdfs:label "CreateMessageRequest" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:params ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:method ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:params ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:method ],
        [ a owl:Restriction ;
            owl:allValuesFrom mcp:CreateMessageRequestParams ;
            owl:onProperty mcp:params ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "sampling/createMessage" ] ) ] ;
            owl:onProperty mcp:method ],
        mcp:JSONRPCRequest ;
    skos:definition "A request from the server to sample an LLM via the client." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:CreateMessageResultResponse a owl:Class ;
    rdfs:label "CreateMessageResultResponse" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:result ],
        [ a owl:Restriction ;
            owl:allValuesFrom mcp:CreateMessageResult ;
            owl:onProperty mcp:result ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:result ],
        mcp:JSONRPCResultResponse ;
    skos:definition "A successful response from the client for a sampling/createMessage request." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:CreateTaskResultResponse a owl:Class ;
    rdfs:label "CreateTaskResultResponse" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:result ],
        [ a owl:Restriction ;
            owl:allValuesFrom mcp:CreateTaskResult ;
            owl:onProperty mcp:result ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:result ],
        mcp:JSONRPCResultResponse ;
    skos:definition "A successful response for a task-augmented request." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:ElicitRequest a owl:Class ;
    rdfs:label "ElicitRequest" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom mcp:ElicitRequestFormParams ;
            owl:onProperty mcp:params ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:method ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "elicitation/create" ] ) ] ;
            owl:onProperty mcp:method ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:params ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:method ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:params ],
        mcp:JSONRPCRequest ;
    skos:definition "A request from the server to elicit additional information from the user via the client." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:ElicitRequestParams a owl:Class ;
    rdfs:label "ElicitRequestParams" ;
    skos:definition "A union of all elicitation request parameter types." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:ElicitRequestURLParams a owl:Class ;
    rdfs:label "ElicitRequestURLParams" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:elicitationId ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:message ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:mode ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:task ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:elicitationId ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:message ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:url ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                                owl:onDatatype xsd:string ;
                                owl:withRestrictions ( [ xsd:pattern "url" ] ) ] ) ] ;
            owl:onProperty mcp:mode ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty mcp:url ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:task ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:message ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:mode ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:url ],
        [ a owl:Restriction ;
            owl:allValuesFrom mcp:TaskMetadata ;
            owl:onProperty mcp:task ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:elicitationId ] ;
    skos:definition "Parameters for a URL-mode elicitation request." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:ElicitResultResponse a owl:Class ;
    rdfs:label "ElicitResultResponse" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:result ],
        [ a owl:Restriction ;
            owl:allValuesFrom mcp:ElicitResult ;
            owl:onProperty mcp:result ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:result ],
        mcp:JSONRPCResultResponse ;
    skos:definition "A successful response from the client for an elicitation/create request." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:ElicitationCompleteNotification a owl:Class ;
    rdfs:label "ElicitationCompleteNotification" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:method ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:params ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "notifications/elicitation/complete" ] ) ] ;
            owl:onProperty mcp:method ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:params ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:method ],
        [ a owl:Restriction ;
            owl:allValuesFrom mcp:ElicitationCompleteNotificationParams ;
            owl:onProperty mcp:params ],
        mcp:JSONRPCNotification ;
    skos:definition "Notification from the server that an out-of-band elicitation request completed." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:EmbeddedResource a owl:Class ;
    rdfs:label "EmbeddedResource" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:type ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                                owl:onDatatype xsd:string ;
                                owl:withRestrictions ( [ xsd:pattern "resource" ] ) ] ) ] ;
            owl:onProperty mcp:type ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:resource ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:resource ],
        [ a owl:Restriction ;
            owl:allValuesFrom mcp:ResourceContents ;
            owl:onProperty mcp:resource ],
        mcp:HasAnnotations,
        mcp:HasMeta ;
    skos:definition "The contents of a resource, embedded into a prompt or tool call result." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:EnumSchema a owl:Class ;
    rdfs:label "EnumSchema" ;
    skos:definition "A union of all enum schema types." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:GetPromptRequest a owl:Class ;
    rdfs:label "GetPromptRequest" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom mcp:GetPromptRequestParams ;
            owl:onProperty mcp:params ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:method ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:params ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "prompts/get" ] ) ] ;
            owl:onProperty mcp:method ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:method ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:params ],
        mcp:JSONRPCRequest ;
    skos:definition "Used by the client to get a prompt provided by the server." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:GetPromptResultResponse a owl:Class ;
    rdfs:label "GetPromptResultResponse" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:result ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:result ],
        [ a owl:Restriction ;
            owl:allValuesFrom mcp:GetPromptResult ;
            owl:onProperty mcp:result ],
        mcp:JSONRPCResultResponse ;
    skos:definition "A successful response from the server for a prompts/get request." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:GetTaskPayloadRequest a owl:Class ;
    rdfs:label "GetTaskPayloadRequest" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:method ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "tasks/result" ] ) ] ;
            owl:onProperty mcp:method ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:method ],
        mcp:JSONRPCRequest ;
    skos:definition "A request to retrieve the result of a completed task." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:GetTaskPayloadResultResponse a owl:Class ;
    rdfs:label "GetTaskPayloadResultResponse" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:result ],
        [ a owl:Restriction ;
            owl:allValuesFrom mcp:GetTaskPayloadResult ;
            owl:onProperty mcp:result ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:result ],
        mcp:JSONRPCResultResponse ;
    skos:definition "A successful response for a tasks/result request." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:GetTaskRequest a owl:Class ;
    rdfs:label "GetTaskRequest" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "tasks/get" ] ) ] ;
            owl:onProperty mcp:method ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:method ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:method ],
        mcp:JSONRPCRequest ;
    skos:definition "A request to retrieve the state of a task." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:GetTaskResultResponse a owl:Class ;
    rdfs:label "GetTaskResultResponse" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:result ],
