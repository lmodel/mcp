mcp:elicitationId a owl:DatatypeProperty ;
    rdfs:label "elicitationId" ;
    rdfs:range xsd:string ;
    skos:definition "The ID of the elicitation." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:items a owl:ObjectProperty ;
