        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:title ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:title ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:name ] ;
    skos:altLabel "BaseMetadata" ;
    skos:definition "Mixin for types that carry name and title." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

