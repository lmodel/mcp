    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:ContentBlock a owl:Class ;
    rdfs:label "ContentBlock" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:text ],
