    linkml:permissible_values <https://w3id.org/lmodel/mcp/NumberTypeEnum#integer>,
        <https://w3id.org/lmodel/mcp/NumberTypeEnum#number> .

<https://w3id.org/lmodel/mcp/NumberTypeEnum#integer> a owl:Class ;
