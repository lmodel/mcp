    rdfs:range xsd:string ;
    skos:definition "Location value." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:role a owl:ObjectProperty ;
    rdfs:label "role" ;
    rdfs:range mcp:Role ;
