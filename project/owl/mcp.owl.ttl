mcp:Error a owl:Class ;
    rdfs:label "Error" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:code ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:code ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:message ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:message ],
        [ a owl:Restriction ;
            owl:allValuesFrom mcp:ErrorData ;
            owl:onProperty mcp:data ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:message ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:data ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty mcp:code ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:data ] ;
    skos:definition "A JSON-RPC error object." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:HasAnnotations a owl:Class ;
