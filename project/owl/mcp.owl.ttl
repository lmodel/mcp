    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:StructuredContentData a owl:Class ;
    rdfs:label "StructuredContentData" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:conditions ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:humidity ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:float ;
            owl:onProperty mcp:humidity ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:humidity ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:temperature ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:conditions ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:temperature ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:conditions ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:float ;
            owl:onProperty mcp:temperature ] ;
    skos:definition "Structured content object returned by tools." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:Tool a owl:Class ;
    rdfs:label "Tool" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:inputSchema ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom mcp:JsonSchema ;
            owl:onProperty mcp:outputSchema ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:outputSchema ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:annotations ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:description ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:execution ],
        [ a owl:Restriction ;
            owl:allValuesFrom mcp:ToolAnnotations ;
            owl:onProperty mcp:annotations ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom mcp:JsonSchema ;
            owl:onProperty mcp:inputSchema ],
        [ a owl:Restriction ;
            owl:allValuesFrom mcp:ToolExecution ;
            owl:onProperty mcp:execution ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:execution ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:annotations ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:outputSchema ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:inputSchema ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:description ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:name ],
        mcp:HasIcons,
        mcp:HasMeta,
        mcp:HasName ;
    skos:definition "Definition for a tool the client can call." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:_meta a owl:ObjectProperty ;
    rdfs:label "_meta" ;
    rdfs:range mcp:MetaObject ;
    skos:definition "Optional metadata object." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:a a owl:ObjectProperty ;
    rdfs:label "a" ;
    rdfs:range mcp:JsonSchema ;
    skos:definition "JSON Schema property for key a." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:action a owl:ObjectProperty ;
    rdfs:label "action" ;
    rdfs:range mcp:ElicitActionEnum ;
    skos:definition "The user action in response to the elicitation." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:additionalProperties a owl:DatatypeProperty ;
    rdfs:label "additionalProperties" ;
    rdfs:range xsd:boolean ;
    skos:definition "JSON Schema additionalProperties flag." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:apps_extension a owl:ObjectProperty ;
    rdfs:label "apps_extension" ;
    rdfs:range mcp:ExtensionAppCapability ;
    skos:altLabel "io.modelcontextprotocol/apps" ;
    skos:definition "Extension capability entry for app mime types." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:argument a owl:ObjectProperty ;
    rdfs:label "argument" ;
    rdfs:range mcp:CompletionArgument ;
    skos:definition "The argument's information." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:b a owl:ObjectProperty ;
    rdfs:label "b" ;
    rdfs:range mcp:JsonSchema ;
    skos:definition "JSON Schema property for key b." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:clientInfo a owl:ObjectProperty ;
    rdfs:label "clientInfo" ;
    rdfs:range mcp:Implementation ;
    skos:definition "Information about the client implementation." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:code a owl:DatatypeProperty ;
    rdfs:label "code" ;
    rdfs:range xsd:integer ;
    skos:definition "The error type that occurred." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:completion a owl:ObjectProperty ;
    rdfs:label "completion" ;
    rdfs:range mcp:CompletionData ;
    skos:definition "The completion result object." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:context a owl:ObjectProperty ;
    rdfs:label "context" ;
    rdfs:range mcp:CompletionContext ;
    skos:definition "Optional completion context." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:costPriority a owl:DatatypeProperty ;
    rdfs:label "costPriority" ;
    rdfs:range xsd:float ;
    skos:definition "How much to prioritize cost when selecting a model (0-1)." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:cursor a owl:DatatypeProperty ;
    rdfs:label "cursor" ;
    rdfs:range xsd:string ;
    skos:definition "An opaque token representing the current pagination position. If provided, the server should return results starting after this cursor." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:destructiveHint a owl:DatatypeProperty ;
    rdfs:label "destructiveHint" ;
    rdfs:range xsd:boolean ;
    skos:definition "If true, the tool may perform destructive updates." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:details a owl:ObjectProperty ;
    rdfs:label "details" ;
    rdfs:range mcp:LogDetails ;
    skos:definition "Nested log details object." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:execution a owl:ObjectProperty ;
    rdfs:label "execution" ;
    rdfs:range mcp:ToolExecution ;
    skos:definition "Execution-related properties for a tool." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:framework a owl:DatatypeProperty ;
    rdfs:label "framework" ;
    rdfs:range xsd:string ;
    skos:definition "Framework value." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:hasMore a owl:DatatypeProperty ;
    rdfs:label "hasMore" ;
    rdfs:range xsd:boolean ;
    skos:definition "Indicates whether there are additional completion options." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:host a owl:DatatypeProperty ;
    rdfs:label "host" ;
    rdfs:range xsd:string ;
    skos:definition "Host value." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:idempotentHint a owl:DatatypeProperty ;
    rdfs:label "idempotentHint" ;
    rdfs:range xsd:boolean ;
    skos:definition "If true, calling repeatedly with same arguments has no additional effect." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:includeContext a owl:ObjectProperty ;
    rdfs:label "includeContext" ;
    rdfs:range mcp:IncludeContextEnum ;
    skos:definition "A request to include context from one or more MCP servers." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:input a owl:ObjectProperty ;
    rdfs:label "input" ;
    rdfs:range mcp:ToolInput ;
    skos:definition "The arguments to pass to the tool." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:inputSchema a owl:ObjectProperty ;
    rdfs:label "inputSchema" ;
    rdfs:range mcp:JsonSchema ;
    skos:definition "A JSON Schema object defining the expected parameters for the tool." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:instructions a owl:DatatypeProperty ;
    rdfs:label "instructions" ;
    rdfs:range xsd:string ;
    skos:definition "Instructions describing how to use the server and its features." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:intelligencePriority a owl:DatatypeProperty ;
    rdfs:label "intelligencePriority" ;
    rdfs:range xsd:float ;
    skos:definition "How much to prioritize intelligence when selecting a model (0-1)." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:language a owl:DatatypeProperty ;
    rdfs:label "language" ;
    rdfs:range xsd:string ;
    skos:definition "Programming language value." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:lastModified a owl:DatatypeProperty ;
    rdfs:label "lastModified" ;
    rdfs:range xsd:string ;
    skos:definition "The moment the resource was last modified, as an ISO 8601 formatted string." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:logger a owl:DatatypeProperty ;
    rdfs:label "logger" ;
    rdfs:range xsd:string ;
    skos:definition "An optional name of the logger issuing this message." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:maxTokens a owl:DatatypeProperty ;
    rdfs:label "maxTokens" ;
    rdfs:range xsd:integer ;
    skos:definition "The requested maximum number of tokens to sample." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:model a owl:DatatypeProperty ;
    rdfs:label "model" ;
    rdfs:range xsd:string ;
    skos:definition "The name of the model that generated the message." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:modelPreferences a owl:ObjectProperty ;
    rdfs:label "modelPreferences" ;
    rdfs:range mcp:ModelPreferences ;
    skos:definition "Model preferences for sampling." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:openWorldHint a owl:DatatypeProperty ;
    rdfs:label "openWorldHint" ;
    rdfs:range xsd:boolean ;
    skos:definition "If true, tool may interact with an open world of external entities." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:outputSchema a owl:ObjectProperty ;
    rdfs:label "outputSchema" ;
    rdfs:range mcp:JsonSchema ;
    skos:definition "An optional JSON Schema object defining the structure of the tool's output." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:port a owl:DatatypeProperty ;
    rdfs:label "port" ;
    rdfs:range xsd:integer ;
    skos:definition "Port value." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:priority a owl:DatatypeProperty ;
    rdfs:label "priority" ;
    rdfs:range xsd:float ;
    skos:definition "How important this data is for operating the server. 1 means most important (required), 0 means least important (optional)." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:progress a owl:DatatypeProperty ;
    rdfs:label "progress" ;
    rdfs:range xsd:float ;
    skos:definition "The progress thus far." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:properties a owl:ObjectProperty ;
    rdfs:label "properties" ;
    rdfs:range mcp:SchemaProperties ;
    skos:definition "JSON Schema properties map." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:readOnlyHint a owl:DatatypeProperty ;
    rdfs:label "readOnlyHint" ;
    rdfs:range xsd:boolean ;
    skos:definition "If true, the tool does not modify its environment." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:ref a owl:ObjectProperty ;
    rdfs:label "ref" ;
    rdfs:range mcp:PromptReference ;
    skos:definition "A prompt or resource template reference." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:requestId a owl:DatatypeProperty ;
    rdfs:label "requestId" ;
    rdfs:range xsd:string ;
    skos:definition "The ID of a request." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:requestedSchema a owl:ObjectProperty ;
    rdfs:label "requestedSchema" ;
    rdfs:range mcp:JsonSchema ;
    skos:definition "A restricted subset of JSON Schema." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:requests a owl:ObjectProperty ;
    rdfs:label "requests" ;
    rdfs:range mcp:TaskRequestCapabilities ;
    skos:definition "Task request capabilities." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:required a owl:DatatypeProperty ;
    rdfs:label "required" ;
    rdfs:range xsd:boolean ;
    skos:definition "Whether this argument must be provided." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:required_field a owl:DatatypeProperty ;
    rdfs:label "required_field" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "required" ;
    skos:definition "Whether this argument must be provided." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:resource a owl:ObjectProperty ;
    rdfs:label "resource" ;
    rdfs:range mcp:ResourceContents ;
    skos:definition "The embedded resource contents (text or blob)." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:schemaUri a owl:DatatypeProperty ;
    rdfs:label "schemaUri" ;
    rdfs:range xsd:string ;
    skos:altLabel "$schema" ;
    skos:definition "Optional JSON Schema dialect identifier." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:serverInfo a owl:ObjectProperty ;
    rdfs:label "serverInfo" ;
    rdfs:range mcp:Implementation ;
    skos:definition "Information about the server implementation." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:speedPriority a owl:DatatypeProperty ;
    rdfs:label "speedPriority" ;
    rdfs:range xsd:float ;
    skos:definition "How much to prioritize sampling speed when selecting a model (0-1)." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:src a owl:DatatypeProperty ;
    rdfs:label "src" ;
    rdfs:range xsd:anyURI ;
    skos:definition "A standard URI pointing to an icon resource." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:stopReason a owl:DatatypeProperty ;
    rdfs:label "stopReason" ;
    rdfs:range xsd:string ;
    skos:definition "The reason why sampling stopped, if known." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:subscribe a owl:DatatypeProperty ;
    rdfs:label "subscribe" ;
    rdfs:range xsd:boolean ;
    skos:definition "Whether subscribing to resource updates is supported." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:systemPrompt a owl:DatatypeProperty ;
    rdfs:label "systemPrompt" ;
    rdfs:range xsd:string ;
    skos:definition "An optional system prompt the server wants to use for sampling." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:taskSupport a owl:ObjectProperty ;
    rdfs:label "taskSupport" ;
    rdfs:range mcp:TaskSupportEnum ;
    skos:definition "Whether this tool supports task-augmented execution." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:theme a owl:ObjectProperty ;
    rdfs:label "theme" ;
    rdfs:range mcp:IconThemeEnum ;
    skos:definition "Optional theme specifier for the icon." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:toolChoice a owl:ObjectProperty ;
    rdfs:label "toolChoice" ;
    rdfs:range mcp:ToolChoice ;
    skos:definition "Controls how the model uses tools." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:toolUseId a owl:DatatypeProperty ;
    rdfs:label "toolUseId" ;
    rdfs:range xsd:string ;
    skos:definition "The ID of the tool use this result corresponds to." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:uriTemplate a owl:DatatypeProperty ;
    rdfs:label "uriTemplate" ;
    rdfs:range xsd:string ;
    skos:definition "A URI template (RFC 6570) for constructing resource URIs." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:value a owl:DatatypeProperty ;
    rdfs:label "value" ;
    rdfs:range xsd:string ;
    skos:definition "A value string." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:version a owl:DatatypeProperty ;
    rdfs:label "version" ;
    rdfs:range xsd:string ;
    skos:definition "The version of this implementation." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:websiteUrl a owl:DatatypeProperty ;
    rdfs:label "websiteUrl" ;
    rdfs:range xsd:anyURI ;
    skos:definition "An optional URL of the website for this implementation." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:ArgumentMap a owl:Class ;
    rdfs:label "ArgumentMap" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:language ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:city ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:city ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:location ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:framework ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:language ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:city ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:location ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:location ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:language ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:framework ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:framework ] ;
    skos:definition "Argument object used in prompt and tool calls." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:IconThemeEnum a owl:Class ;
    rdfs:label "IconThemeEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/mcp/IconThemeEnum#dark> <https://w3id.org/lmodel/mcp/IconThemeEnum#light> ) ;
    skos:definition "Theme specifier for an icon." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> ;
    linkml:permissible_values <https://w3id.org/lmodel/mcp/IconThemeEnum#dark>,
        <https://w3id.org/lmodel/mcp/IconThemeEnum#light> .

mcp:Implementation a owl:Class ;
    rdfs:label "Implementation" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:websiteUrl ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty mcp:websiteUrl ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:description ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:version ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:version ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:description ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:version ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:websiteUrl ],
        mcp:HasIcons,
        mcp:HasName ;
    skos:definition "Describes the MCP implementation." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:ResourceContents a owl:Class ;
    rdfs:label "ResourceContents" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:uri ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:text ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:text ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:text ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:mimeType ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:blob ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:mimeType ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty mcp:uri ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:mimeType ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:uri ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:blob ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:blob ],
        mcp:HasMeta ;
    skos:definition "Generic resource contents." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:SchemaItems a owl:Class ;
    rdfs:label "SchemaItems" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:enum ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:enum ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom mcp:EnumOption ;
            owl:onProperty mcp:anyOf ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:anyOf ] ;
    skos:definition "JSON Schema items expression used by enum multi-select schemas." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:Task a owl:Class ;
    rdfs:label "Task" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:statusMessage ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:createdAt ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:lastUpdatedAt ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:pollInterval ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:taskId ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:lastUpdatedAt ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:createdAt ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:statusMessage ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty mcp:ttl ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty mcp:pollInterval ],
        [ a owl:Restriction ;
            owl:allValuesFrom mcp:TaskStatusEnum ;
            owl:onProperty mcp:status ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:taskId ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:ttl ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:pollInterval ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:ttl ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:status ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:taskId ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:statusMessage ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:lastUpdatedAt ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:status ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:createdAt ] ;
    skos:definition "Data associated with a task." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:TaskMetadata a owl:Class ;
    rdfs:label "TaskMetadata" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty mcp:ttl ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:ttl ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:ttl ] ;
