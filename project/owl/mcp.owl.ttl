    linkml:permissible_values <https://w3id.org/lmodel/mcp/StringFormatEnum#date>,
        <https://w3id.org/lmodel/mcp/StringFormatEnum#date-time>,
        <https://w3id.org/lmodel/mcp/StringFormatEnum#email>,
        <https://w3id.org/lmodel/mcp/StringFormatEnum#uri> .

mcp:HasName a owl:Class ;
    rdfs:label "HasName" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
