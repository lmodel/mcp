mcp:LoggingLevel a owl:Class ;
    rdfs:label "LoggingLevel" ;
    rdfs:seeAlso <https://datatracker.ietf.org/doc/html/rfc5424#section-6.2.1> ;
    owl:unionOf ( <https://w3id.org/lmodel/mcp/LoggingLevel#alert> <https://w3id.org/lmodel/mcp/LoggingLevel#critical> <https://w3id.org/lmodel/mcp/LoggingLevel#debug> <https://w3id.org/lmodel/mcp/LoggingLevel#emergency> <https://w3id.org/lmodel/mcp/LoggingLevel#error> <https://w3id.org/lmodel/mcp/LoggingLevel#info> <https://w3id.org/lmodel/mcp/LoggingLevel#notice> <https://w3id.org/lmodel/mcp/LoggingLevel#warning> ) ;
    skos:definition "The severity of a log message. Maps to syslog message severities (RFC-5424)." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> ;
    linkml:permissible_values <https://w3id.org/lmodel/mcp/LoggingLevel#alert>,
        <https://w3id.org/lmodel/mcp/LoggingLevel#critical>,
        <https://w3id.org/lmodel/mcp/LoggingLevel#debug>,
        <https://w3id.org/lmodel/mcp/LoggingLevel#emergency>,
        <https://w3id.org/lmodel/mcp/LoggingLevel#error>,
        <https://w3id.org/lmodel/mcp/LoggingLevel#info>,
        <https://w3id.org/lmodel/mcp/LoggingLevel#notice>,
        <https://w3id.org/lmodel/mcp/LoggingLevel#warning> .

mcp:arguments a owl:ObjectProperty ;
    rdfs:label "arguments" ;
    rdfs:range mcp:ArgumentMap ;
    skos:definition "Arguments for templating." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

xsd:anyType a rdfs:Datatype .

mcp:createdAt a owl:DatatypeProperty ;
    rdfs:label "createdAt" ;
    rdfs:range xsd:string ;
    skos:definition "ISO 8601 timestamp when the task was created." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:data a owl:DatatypeProperty ;
    rdfs:label "data" ;
    rdfs:range xsd:string ;
    skos:definition "Base64-encoded binary data." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:id a owl:DatatypeProperty ;
    rdfs:label "id" ;
    rdfs:range xsd:string ;
    skos:definition "Uniquely identifying ID for a JSON-RPC request." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:jsonrpc a owl:DatatypeProperty ;
    rdfs:label "jsonrpc" ;
    rdfs:range xsd:string ;
    skos:definition "JSON-RPC version string." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:lastUpdatedAt a owl:DatatypeProperty ;
    rdfs:label "lastUpdatedAt" ;
    rdfs:range xsd:string ;
    skos:definition "ISO 8601 timestamp when the task was last updated." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:listChanged a owl:DatatypeProperty ;
    rdfs:label "listChanged" ;
    rdfs:range xsd:boolean ;
    skos:definition "Whether notifications for list changes are supported." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:mode a owl:DatatypeProperty ;
    rdfs:label "mode" ;
    rdfs:range xsd:string ;
    skos:definition "The elicitation mode." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:pollInterval a owl:DatatypeProperty ;
    rdfs:label "pollInterval" ;
    rdfs:range xsd:integer ;
    skos:definition "Suggested polling interval in milliseconds." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:status a owl:ObjectProperty ;
    rdfs:label "status" ;
    rdfs:range mcp:TaskStatusEnum ;
    skos:definition "Current task state." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:statusMessage a owl:DatatypeProperty ;
    rdfs:label "statusMessage" ;
    rdfs:range xsd:string ;
    skos:definition "Optional human-readable message describing the current task state." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:text a owl:DatatypeProperty ;
    rdfs:label "text" ;
    rdfs:range xsd:string ;
    skos:definition "Text content." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:message a owl:DatatypeProperty ;
    rdfs:label "message" ;
    rdfs:range xsd:string ;
    skos:definition "A message string." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:nextCursor a owl:DatatypeProperty ;
    rdfs:label "nextCursor" ;
    rdfs:range xsd:string ;
    skos:definition "An opaque token representing the pagination position after the last returned result. If present, there may be more results available." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:task a owl:ObjectProperty ;
    rdfs:label "task" ;
    rdfs:range mcp:Task ;
    skos:definition "Task data." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:taskId a owl:DatatypeProperty ;
    rdfs:label "taskId" ;
    rdfs:range xsd:string ;
    skos:definition "The task identifier." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:ttl a owl:DatatypeProperty ;
    rdfs:label "ttl" ;
    rdfs:range xsd:integer ;
    skos:definition "Actual retention duration from creation in milliseconds, null for unlimited." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:content a owl:ObjectProperty ;
    rdfs:label "content" ;
    rdfs:range mcp:ContentBlock ;
    skos:definition "Structured content block of a message or result." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:JsonSchema a owl:Class ;
    rdfs:label "JsonSchema" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:required_list ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:maxLength ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:maximum ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty mcp:minimum ],
        [ a owl:Restriction ;
            owl:allValuesFrom mcp:EnumOption ;
            owl:onProperty mcp:anyOf ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:required_list ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty mcp:minLength ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:properties ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:minLength ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:default ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:title ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:minimum ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:description ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:minimum ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:schemaUri ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty mcp:additionalProperties ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:properties ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:title ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:description ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:format ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:title ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:additionalProperties ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:items ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty mcp:maxLength ],
        [ a owl:Restriction ;
            owl:allValuesFrom mcp:SchemaItems ;
            owl:onProperty mcp:items ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:oneOf ],
        [ a owl:Restriction ;
            owl:allValuesFrom mcp:StringFormatEnum ;
            owl:onProperty mcp:format ],
        [ a owl:Restriction ;
            owl:allValuesFrom mcp:EnumOption ;
            owl:onProperty mcp:oneOf ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:const ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:minLength ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyType ;
            owl:onProperty mcp:default ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:items ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:maxLength ],
        [ a owl:Restriction ;
            owl:allValuesFrom mcp:SchemaProperties ;
            owl:onProperty mcp:properties ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:maximum ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:default ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty mcp:maximum ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:enum ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:additionalProperties ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:schemaUri ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:anyOf ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:const ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:enum ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:schemaUri ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:description ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:format ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:const ] ;
    skos:definition "Restricted JSON Schema object used in MCP payloads." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:JSONRPCRequest a owl:Class ;
    rdfs:label "JSONRPCRequest" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:method ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:method ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:jsonrpc ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:jsonrpc ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:jsonrpc ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:method ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:id ] ;
    skos:altLabel "PaginatedRequest",
        "Request" ;
    skos:definition "A request that expects a response." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:JSONRPCResultResponse a owl:Class ;
    rdfs:label "JSONRPCResultResponse" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:jsonrpc ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:jsonrpc ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:jsonrpc ] ;
    skos:definition "A successful (non-error) response to a request." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:Result a owl:Class ;
    rdfs:label "Result" ;
    rdfs:subClassOf mcp:HasMeta ;
    skos:altLabel "EmptyResult",
        "PaginatedResult" ;
    skos:definition "Common result fields." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:default_value a owl:DatatypeProperty ;
    rdfs:label "default_value" ;
    rdfs:range xsd:string ;
    skos:altLabel "default" ;
    skos:definition "Default value for a schema field." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:HasMeta a owl:Class ;
    rdfs:label "HasMeta" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom mcp:MetaObject ;
            owl:onProperty mcp:_meta ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:_meta ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:_meta ] ;
    skos:altLabel "NotificationParams",
        "RequestParams" ;
    skos:definition "Mixin for types that carry a _meta field." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:default a owl:DatatypeProperty ;
    rdfs:label "default" ;
    rdfs:range xsd:anyType ;
    skos:definition "Default value for a schema field." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:mimeType a owl:DatatypeProperty ;
    rdfs:label "mimeType" ;
    rdfs:range xsd:string ;
    skos:definition "The MIME type of a resource, if known." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:uri a owl:DatatypeProperty ;
    rdfs:label "uri" ;
    rdfs:range xsd:anyURI ;
    skos:definition "A resource URI." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:title a owl:DatatypeProperty ;
    rdfs:label "title" ;
    rdfs:range xsd:string ;
    skos:definition "Intended for UI and end-user contexts — optimized to be human-readable and easily understood." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:params a owl:DatatypeProperty ;
    rdfs:label "params" ;
    rdfs:range xsd:string ;
    skos:definition "JSON-RPC parameters payload." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:description a owl:DatatypeProperty ;
    rdfs:label "description" ;
    rdfs:range xsd:string ;
    skos:definition "A human-readable description." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:name a owl:DatatypeProperty ;
    rdfs:label "name" ;
    rdfs:range xsd:string ;
    skos:definition "Intended for programmatic or logical use, but used as a display name in past specs or fallback (if title is not present)." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:type a owl:DatatypeProperty ;
    rdfs:label "type" ;
    rdfs:range xsd:string ;
    skos:definition "Type discriminator field." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:result a owl:ObjectProperty ;
    rdfs:label "result" ;
    rdfs:range mcp:Result ;
    skos:definition "JSON-RPC successful result payload." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:method a owl:DatatypeProperty ;
    rdfs:label "method" ;
    rdfs:range xsd:string ;
    skos:definition "The JSON-RPC method name." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

xsd:string a rdfs:Datatype .


