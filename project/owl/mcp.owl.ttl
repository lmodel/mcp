    linkml:permissible_values <https://w3id.org/lmodel/mcp/Role#assistant>,
        <https://w3id.org/lmodel/mcp/Role#user> .

mcp:enum a owl:DatatypeProperty ;
    rdfs:label "enum" ;
    rdfs:range xsd:string ;
    skos:definition "Array of enum values." ;
