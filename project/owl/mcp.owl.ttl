mcp:Prompt a owl:Class ;
    rdfs:label "Prompt" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:name ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:description ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom mcp:PromptArgument ;
            owl:onProperty mcp:arguments ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:description ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:arguments ],
        mcp:HasIcons,
        mcp:HasMeta,
        mcp:HasName ;
    skos:definition "A prompt or prompt template that the server offers." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:PromptReference a owl:Class ;
    rdfs:label "PromptReference" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                                owl:onDatatype xsd:string ;
                                owl:withRestrictions ( [ xsd:pattern "ref/prompt" ] ) ] ) ] ;
            owl:onProperty mcp:type ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:type ],
        mcp:HasName ;
    skos:definition "Identifies a prompt." ;
    skos:inScheme <https://w3id.org/lmodel/mcp> .

mcp:Resource a owl:Class ;
    rdfs:label "Resource" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty mcp:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty mcp:mimeType ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mcp:mimeType ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty mcp:uri ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty mcp:size ],
