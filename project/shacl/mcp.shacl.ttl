            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path mcp:isError ] ;
    sh:targetClass mcp:CallToolResult .

mcp:CancelTaskResult a sh:NodeShape ;
    rdfs:comment "The result returned for a tasks/cancel request." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "ISO 8601 timestamp when the task was last updated." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path mcp:lastUpdatedAt ],
        [ sh:class mcp:MetaObject ;
            sh:description "Optional metadata object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path mcp:_meta ],
        [ sh:datatype xsd:string ;
            sh:description "Optional human-readable message describing the current task state." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path mcp:statusMessage ],
        [ sh:datatype xsd:string ;
            sh:description "The task identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path mcp:taskId ],
        [ sh:datatype xsd:string ;
            sh:description "ISO 8601 timestamp when the task was created." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path mcp:createdAt ],
        [ sh:datatype xsd:integer ;
            sh:description "Actual retention duration from creation in milliseconds, null for unlimited." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path mcp:ttl ],
        [ sh:description "Current task state." ;
            sh:in ( "cancelled" "completed" "failed" "input_required" "working" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path mcp:status ],
        [ sh:datatype xsd:integer ;
            sh:description "Suggested polling interval in milliseconds." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path mcp:pollInterval ] ;
    sh:targetClass mcp:CancelTaskResult .

mcp:CancelledNotificationParams a sh:NodeShape ;
    rdfs:comment "Parameters for a notifications/cancelled notification." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The ID of a request." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path mcp:requestId ],
        [ sh:class mcp:MetaObject ;
            sh:description "Optional metadata object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path mcp:_meta ],
        [ sh:datatype xsd:string ;
            sh:description "An optional string describing the reason." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path mcp:reason ] ;
    sh:targetClass mcp:CancelledNotificationParams .

mcp:ClientCapabilities a sh:NodeShape ;
    rdfs:comment "Capabilities a client may support. Known capabilities are defined here, but this is not a closed set." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class mcp:RootsCapability ;
            sh:description "The list of roots." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path mcp:roots ],
        [ sh:datatype xsd:anyType ;
            sh:description "Experimental capability extensions." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path mcp:experimental ],
        [ sh:class mcp:ExtensionsCapability ;
            sh:description "Implementation-specific extension capabilities." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path mcp:extensions ],
        [ sh:class mcp:TasksCapability ;
            sh:description "The list of tasks." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path mcp:tasks ],
        [ sh:class mcp:ElicitationCapability ;
            sh:description "Elicitation capability object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path mcp:elicitation ],
        [ sh:class mcp:SamplingCapability ;
            sh:description "Sampling capability object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path mcp:sampling ] ;
    sh:targetClass mcp:ClientCapabilities .

mcp:CompleteRequestParams a sh:NodeShape ;
    rdfs:comment "Parameters for a completion/complete request." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class mcp:CompletionContext ;
            sh:description "Optional completion context." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path mcp:context ],
        [ sh:class mcp:PromptReference ;
            sh:description "A prompt or resource template reference." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path mcp:ref ],
        [ sh:class mcp:CompletionArgument ;
            sh:description "The argument's information." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path mcp:argument ] ;
    sh:targetClass mcp:CompleteRequestParams .

mcp:CompleteResult a sh:NodeShape ;
    rdfs:comment "The result returned by the server for a completion/complete request." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class mcp:CompletionData ;
            sh:description "The completion result object." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path mcp:completion ],
        [ sh:class mcp:MetaObject ;
            sh:description "Optional metadata object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path mcp:_meta ] ;
    sh:targetClass mcp:CompleteResult .

mcp:CompletionArgument a sh:NodeShape ;
    rdfs:comment "Argument descriptor for completion requests." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Intended for programmatic or logical use, but used as a display name in past specs or fallback (if title is not present)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path schema1:name ],
        [ sh:datatype xsd:string ;
            sh:description "A value string." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path mcp:value ] ;
    sh:targetClass mcp:CompletionArgument .

mcp:CompletionContext a sh:NodeShape ;
    rdfs:comment "Additional context for completion requests." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class mcp:ArgumentMap ;
            sh:description "Arguments for templating." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path mcp:arguments ] ;
    sh:targetClass mcp:CompletionContext .

mcp:CompletionData a sh:NodeShape ;
    rdfs:comment "Completion result payload." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether there are additional completion options." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path mcp:hasMore ],
        [ sh:datatype xsd:string ;
            sh:description "An array of completion values." ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path mcp:values ],
        [ sh:datatype xsd:float ;
            sh:description "Total number of items to process (or total progress required), if known." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path mcp:total ] ;
    sh:targetClass mcp:CompletionData .

mcp:CreateMessageRequestParams a sh:NodeShape ;
    rdfs:comment "Parameters for a sampling/createMessage request." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class mcp:TaskMetadata ;
            sh:description "If specified, task-augmented execution." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path mcp:task ],
        [ sh:datatype xsd:string ;
            sh:description "An optional system prompt the server wants to use for sampling." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path mcp:systemPrompt ],
        [ sh:datatype xsd:integer ;
            sh:description "The requested maximum number of tokens to sample." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path mcp:maxTokens ],
        [ sh:class mcp:Tool ;
            sh:description "Tools that the model may use during generation." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path mcp:tools ],
        [ sh:class mcp:ToolChoice ;
            sh:description "Controls how the model uses tools." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path mcp:toolChoice ],
        [ sh:class mcp:SamplingMessage ;
            sh:description "Messages for sampling." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path mcp:messages ],
        [ sh:description "A request to include context from one or more MCP servers." ;
            sh:in ( "allServers" "none" "thisServer" ) ;
            sh:maxCount 1 ;
            sh:order 5 ;
            sh:path mcp:includeContext ],
        [ sh:datatype xsd:string ;
            sh:description "Stop sequences for sampling." ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path mcp:stopSequences ],
        [ sh:class mcp:ModelPreferences ;
            sh:description "Model preferences for sampling." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path mcp:modelPreferences ],
        [ sh:datatype xsd:float ;
            sh:description "Sampling temperature." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path mcp:temperature ] ;
    sh:targetClass mcp:CreateMessageRequestParams .

mcp:CreateMessageResult a sh:NodeShape ;
    rdfs:comment "The result returned by the client for a sampling/createMessage request." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The role of the sender or recipient." ;
            sh:in ( "assistant" "user" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 2 ;
            sh:path mcp:role ],
        [ sh:datatype xsd:string ;
            sh:description "The reason why sampling stopped, if known." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path mcp:stopReason ],
        [ sh:description "The message content." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:or ( [ sh:class mcp:ContentBlock ] [ sh:class mcp:ContentBlock ] ) ;
            sh:order 0 ;
            sh:path mcp:content ],
        [ sh:class mcp:MetaObject ;
            sh:description "Optional metadata object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path mcp:_meta ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the model that generated the message." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path mcp:model ] ;
    sh:targetClass mcp:CreateMessageResult .

mcp:CreateTaskResult a sh:NodeShape ;
    rdfs:comment "The result returned for a task-augmented request." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class mcp:MetaObject ;
            sh:description "Optional metadata object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path mcp:_meta ],
        [ sh:class mcp:Task ;
            sh:description "Task data." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path mcp:task ] ;
    sh:targetClass mcp:CreateTaskResult .

mcp:ElicitRequestFormParams a sh:NodeShape ;
    rdfs:comment "Parameters for a form-mode elicitation request." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
