mcp:ElicitRequest a sh:NodeShape ;
    rdfs:comment "A request from the server to elicit additional information from the user via the client." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Uniquely identifying ID for a JSON-RPC request." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path mcp:id ],
        [ sh:datatype xsd:string ;
            sh:description "JSON-RPC version string." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path mcp:jsonrpc ],
        [ sh:class mcp:ElicitRequestFormParams ;
            sh:description "JSON-RPC parameters payload." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path mcp:params ],
        [ sh:datatype xsd:string ;
            sh:description "The JSON-RPC method name." ;
            sh:in ( "elicitation/create" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path mcp:method ] ;
    sh:targetClass mcp:ElicitRequest .

mcp:ElicitRequestParams a sh:NodeShape ;
    rdfs:comment "A union of all elicitation request parameter types." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass mcp:ElicitRequestParams .

mcp:ElicitRequestURLParams a sh:NodeShape ;
    rdfs:comment "Parameters for a URL-mode elicitation request." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The ID of the elicitation." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path mcp:elicitationId ],
        [ sh:datatype xsd:anyURI ;
            sh:description "The URL that the user should navigate to." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path mcp:url ],
        [ sh:datatype xsd:string ;
            sh:description "A message string." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path mcp:message ],
        [ sh:class mcp:TaskMetadata ;
            sh:description "If specified, task-augmented execution." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path mcp:task ],
        [ sh:datatype xsd:string ;
            sh:description "The elicitation mode." ;
            sh:in ( "url" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path mcp:mode ] ;
    sh:targetClass mcp:ElicitRequestURLParams .

mcp:ElicitResultResponse a sh:NodeShape ;
    rdfs:comment "A successful response from the client for an elicitation/create request." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Uniquely identifying ID for a JSON-RPC request." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path mcp:id ],
        [ sh:datatype xsd:string ;
            sh:description "JSON-RPC version string." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path mcp:jsonrpc ],
        [ sh:class mcp:ElicitResult ;
            sh:description "JSON-RPC successful result payload." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path mcp:result ] ;
    sh:targetClass mcp:ElicitResultResponse .

mcp:ElicitationCompleteNotification a sh:NodeShape ;
    rdfs:comment "Notification from the server that an out-of-band elicitation request completed." ;
    sh:closed true ;
