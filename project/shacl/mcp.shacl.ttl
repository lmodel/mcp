            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path mcp:id ],
        [ sh:datatype xsd:string ;
            sh:description "JSON-RPC version string." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path mcp:jsonrpc ],
        [ sh:class mcp:GetPromptResult ;
