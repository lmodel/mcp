mcp:ContentBlockVariants a sh:NodeShape ;
    rdfs:comment "A union of all content block types. Maps to the vendor schema ContentBlock anyOf definition." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass mcp:ContentBlockVariants .

