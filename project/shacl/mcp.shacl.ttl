mcp:StringSchema a sh:NodeShape ;
    rdfs:comment "String schema definition." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "Maximum length constraint." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path mcp:maxLength ],
        [ sh:datatype xsd:string ;
            sh:description "Type discriminator field." ;
            sh:in ( "string" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path mcp:type ],
        [ sh:datatype xsd:string ;
            sh:description "Intended for UI and end-user contexts — optimized to be human-readable and easily understood." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path dct:title ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path dct:description ],
        [ sh:datatype xsd:integer ;
            sh:description "Minimum length constraint." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path mcp:minLength ],
        [ sh:datatype xsd:string ;
            sh:description "Default value for a schema field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path mcp:default_value ],
        [ sh:datatype xsd:anyType ;
            sh:description "Default value for a schema field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path mcp:default ],
        [ sh:description "String format constraint." ;
            sh:in ( "date" "date-time" "email" "uri" ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path mcp:format ] ;
    sh:targetClass mcp:StringSchema .

