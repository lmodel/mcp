            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path mcp:action ],
        [ sh:class mcp:ElicitationContent ;
            sh:description "Structured content block of a message or result." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path mcp:content ] ;
    sh:targetClass mcp:ElicitResult .

mcp:ElicitationCompleteNotificationParams a sh:NodeShape ;
