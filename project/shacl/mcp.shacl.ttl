@prefix dct: <http://purl.org/dc/terms/> .
@prefix mcp: <https://w3id.org/lmodel/mcp/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

mcp:AudioContent a sh:NodeShape ;
    rdfs:comment "Audio provided to or from an LLM." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class mcp:MetaObject ;
            sh:description "Optional metadata object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path mcp:_meta ],
        [ sh:datatype xsd:string ;
            sh:description "Base64-encoded binary data." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path mcp:data ],
        [ sh:datatype xsd:string ;
            sh:description "Type discriminator field." ;
            sh:in ( "audio" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path mcp:type ],
        [ sh:datatype xsd:string ;
            sh:description "The MIME type of a resource, if known." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path mcp:mimeType ],
        [ sh:class mcp:Annotations ;
            sh:description "Optional annotations for the client." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path mcp:annotations ] ;
    sh:targetClass mcp:AudioContent .

mcp:BlobResourceContents a sh:NodeShape ;
    rdfs:comment "Blob resource contents." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The MIME type of a resource, if known." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path mcp:mimeType ],
        [ sh:class mcp:MetaObject ;
            sh:description "Optional metadata object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path mcp:_meta ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A resource URI." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path mcp:uri ],
        [ sh:datatype xsd:string ;
            sh:description "A base64-encoded string representing binary data." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path mcp:blob ] ;
    sh:targetClass mcp:BlobResourceContents .

mcp:BooleanSchema a sh:NodeShape ;
    rdfs:comment "Boolean schema definition." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Type discriminator field." ;
            sh:in ( "boolean" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path mcp:type ],
        [ sh:datatype xsd:string ;
            sh:description "Intended for UI and end-user contexts — optimized to be human-readable and easily understood." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path dct:title ],
        [ sh:datatype xsd:boolean ;
            sh:description "Default boolean value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path mcp:default_value ],
        [ sh:datatype xsd:boolean ;
            sh:description "Default value for a schema field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path mcp:default ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path dct:description ] ;
    sh:targetClass mcp:BooleanSchema .

mcp:CallToolRequest a sh:NodeShape ;
    rdfs:comment "Used by the client to invoke a tool provided by the server." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "JSON-RPC version string." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path mcp:jsonrpc ],
        [ sh:class mcp:CallToolRequestParams ;
            sh:description "JSON-RPC parameters payload." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path mcp:params ],
        [ sh:datatype xsd:string ;
            sh:description "The JSON-RPC method name." ;
            sh:in ( "tools/call" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path mcp:method ],
        [ sh:datatype xsd:string ;
            sh:description "Uniquely identifying ID for a JSON-RPC request." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path mcp:id ] ;
    sh:targetClass mcp:CallToolRequest .

mcp:CallToolResultResponse a sh:NodeShape ;
    rdfs:comment "A successful response from the server for a tools/call request." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "JSON-RPC version string." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path mcp:jsonrpc ],
        [ sh:datatype xsd:string ;
            sh:description "Uniquely identifying ID for a JSON-RPC request." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path mcp:id ],
        [ sh:class mcp:CallToolResult ;
            sh:description "JSON-RPC successful result payload." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path mcp:result ] ;
    sh:targetClass mcp:CallToolResultResponse .

mcp:CancelTaskRequest a sh:NodeShape ;
    rdfs:comment "A request to cancel a task." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "JSON-RPC version string." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path mcp:jsonrpc ],
        [ sh:datatype xsd:string ;
            sh:description "The JSON-RPC method name." ;
            sh:in ( "tasks/cancel" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path mcp:method ],
        [ sh:datatype xsd:string ;
            sh:description "Uniquely identifying ID for a JSON-RPC request." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path mcp:id ] ;
    sh:targetClass mcp:CancelTaskRequest .

mcp:CancelTaskResultResponse a sh:NodeShape ;
    rdfs:comment "A successful response for a tasks/cancel request." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
