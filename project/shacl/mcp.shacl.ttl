mcp:GetTaskPayloadRequest a sh:NodeShape ;
    rdfs:comment "A request to retrieve the result of a completed task." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The JSON-RPC method name." ;
            sh:in ( "tasks/result" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path mcp:method ],
        [ sh:datatype xsd:string ;
            sh:description "JSON-RPC version string." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
