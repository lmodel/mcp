            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path mcp:city ],
        [ sh:class mcp:JsonSchema ;
            sh:description "Weather conditions description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path mcp:conditions ] ;
    sh:targetClass mcp:SchemaProperties .

mcp:ServerCapabilities a sh:NodeShape ;
    rdfs:comment "Capabilities that a server may support. Known capabilities are defined here, but this is not a closed set." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class mcp:ExtensionsCapability ;
            sh:description "Implementation-specific extension capabilities." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path mcp:extensions ],
        [ sh:class mcp:ToolsCapability ;
            sh:description "The list of tools." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path mcp:tools ],
        [ sh:datatype xsd:anyType ;
            sh:description "Experimental capability extensions." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path mcp:experimental ],
        [ sh:class mcp:TasksCapability ;
            sh:description "The list of tasks." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path mcp:tasks ],
        [ sh:class mcp:PromptsCapability ;
            sh:description "The list of prompts." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path mcp:prompts ],
        [ sh:class mcp:ResourcesCapability ;
            sh:description "The list of resources." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path mcp:resources ] ;
    sh:targetClass mcp:ServerCapabilities .

mcp:SetLevelRequestParams a sh:NodeShape ;
    rdfs:comment "Parameters for a logging/setLevel request." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The severity of a log message." ;
            sh:in ( "alert" "critical" "debug" "emergency" "error" "info" "notice" "warning" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path mcp:level ] ;
    sh:targetClass mcp:SetLevelRequestParams .

mcp:SubscribeRequestParams a sh:NodeShape ;
    rdfs:comment "Parameters for a resources/subscribe request." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:anyURI ;
            sh:description "A resource URI." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path mcp:uri ] ;
    sh:targetClass mcp:SubscribeRequestParams .

mcp:TaskRequestCapabilities a sh:NodeShape ;
    rdfs:comment "Task request capability map." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class mcp:ToolsCapability ;
            sh:description "The list of tools." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path mcp:tools ],
        [ sh:class mcp:SamplingCapability ;
            sh:description "Sampling capability object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path mcp:sampling ],
        [ sh:class mcp:ElicitationCapability ;
            sh:description "Elicitation capability object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path mcp:elicitation ] ;
    sh:targetClass mcp:TaskRequestCapabilities .

mcp:TaskStatusNotificationParams a sh:NodeShape ;
    rdfs:comment "Parameters for a notifications/tasks/status notification." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "Actual retention duration from creation in milliseconds, null for unlimited." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path mcp:ttl ],
        [ sh:datatype xsd:string ;
            sh:description "The task identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path mcp:taskId ],
        [ sh:description "Current task state." ;
            sh:in ( "cancelled" "completed" "failed" "input_required" "working" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path mcp:status ],
        [ sh:class mcp:MetaObject ;
            sh:description "Optional metadata object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path mcp:_meta ],
        [ sh:datatype xsd:string ;
            sh:description "ISO 8601 timestamp when the task was last updated." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path mcp:lastUpdatedAt ],
        [ sh:datatype xsd:string ;
            sh:description "ISO 8601 timestamp when the task was created." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path mcp:createdAt ],
        [ sh:datatype xsd:string ;
            sh:description "Optional human-readable message describing the current task state." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path mcp:statusMessage ],
        [ sh:datatype xsd:integer ;
            sh:description "Suggested polling interval in milliseconds." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path mcp:pollInterval ] ;
    sh:targetClass mcp:TaskStatusNotificationParams .

mcp:ToolAnnotations a sh:NodeShape ;
    rdfs:comment "Additional properties describing a Tool to clients. All properties are hints, not guarantees." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "If true, the tool does not modify its environment." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path mcp:readOnlyHint ],
        [ sh:datatype xsd:boolean ;
            sh:description "If true, tool may interact with an open world of external entities." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path mcp:openWorldHint ],
        [ sh:datatype xsd:string ;
            sh:description "Intended for UI and end-user contexts — optimized to be human-readable and easily understood." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path dct:title ],
        [ sh:datatype xsd:boolean ;
            sh:description "If true, calling repeatedly with same arguments has no additional effect." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path mcp:idempotentHint ],
        [ sh:datatype xsd:boolean ;
            sh:description "If true, the tool may perform destructive updates." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path mcp:destructiveHint ] ;
    sh:targetClass mcp:ToolAnnotations .

mcp:ToolChoice a sh:NodeShape ;
    rdfs:comment "Controls tool selection behavior for sampling requests." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Controls the tool use ability of the model." ;
            sh:in ( "auto" "none" "required" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path mcp:mode ] ;
    sh:targetClass mcp:ToolChoice .

mcp:ToolExecution a sh:NodeShape ;
    rdfs:comment "Execution-related properties for a tool." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Whether this tool supports task-augmented execution." ;
            sh:in ( "forbidden" "optional" "required" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path mcp:taskSupport ] ;
    sh:targetClass mcp:ToolExecution .

mcp:ToolInput a sh:NodeShape ;
    rdfs:comment "Tool input payload." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "City value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path mcp:city ],
        [ sh:datatype xsd:string ;
            sh:description "Location value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path mcp:location ] ;
    sh:targetClass mcp:ToolInput .

mcp:URLElicitation a sh:NodeShape ;
    rdfs:comment "URL-based elicitation request payload carried in error data." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The ID of the elicitation." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path mcp:elicitationId ],
        [ sh:datatype xsd:anyURI ;
            sh:description "The URL that the user should navigate to." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path mcp:url ],
        [ sh:datatype xsd:string ;
            sh:description "The elicitation mode." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path mcp:mode ],
        [ sh:datatype xsd:string ;
            sh:description "A message string." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path mcp:message ] ;
    sh:targetClass mcp:URLElicitation .

mcp:UnsubscribeRequestParams a sh:NodeShape ;
    rdfs:comment "Parameters for a resources/unsubscribe request." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:anyURI ;
            sh:description "A resource URI." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path mcp:uri ] ;
    sh:targetClass mcp:UnsubscribeRequestParams .

mcp:ElicitationCapability a sh:NodeShape ;
    rdfs:comment "Client elicitation capability." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass mcp:ElicitationCapability .

mcp:Error a sh:NodeShape ;
    rdfs:comment "A JSON-RPC error object." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A message string." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path mcp:message ],
        [ sh:class mcp:ErrorData ;
            sh:description "Base64-encoded binary data." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path mcp:data ],
        [ sh:datatype xsd:integer ;
            sh:description "The error type that occurred." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path mcp:code ] ;
    sh:targetClass mcp:Error .

mcp:ExtensionsCapability a sh:NodeShape ;
    rdfs:comment "Server/client extension capability object." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class mcp:ExtensionAppCapability ;
            sh:description "Extension capability entry for app mime types." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path mcp:apps_extension ] ;
    sh:targetClass mcp:ExtensionsCapability .

mcp:Implementation a sh:NodeShape ;
    rdfs:comment "Describes the MCP implementation." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path dct:description ],
        [ sh:datatype xsd:anyURI ;
            sh:description "An optional URL of the website for this implementation." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path mcp:websiteUrl ],
        [ sh:datatype xsd:string ;
            sh:description "Intended for UI and end-user contexts — optimized to be human-readable and easily understood." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path dct:title ],
        [ sh:datatype xsd:string ;
            sh:description "The version of this implementation." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path mcp:version ],
        [ sh:datatype xsd:string ;
            sh:description "Intended for programmatic or logical use, but used as a display name in past specs or fallback (if title is not present)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path schema1:name ],
        [ sh:class mcp:Icon ;
            sh:description "Optional set of sized icons that the client can display in a user interface." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path mcp:icons ] ;
    sh:targetClass mcp:Implementation .

mcp:ResourceContents a sh:NodeShape ;
    rdfs:comment "Generic resource contents." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:anyURI ;
            sh:description "A resource URI." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path mcp:uri ],
        [ sh:datatype xsd:string ;
            sh:description "Text content." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path mcp:text ],
        [ sh:datatype xsd:string ;
            sh:description "The MIME type of a resource, if known." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path mcp:mimeType ],
        [ sh:datatype xsd:string ;
            sh:description "A base64-encoded string representing binary data." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path mcp:blob ],
        [ sh:class mcp:MetaObject ;
            sh:description "Optional metadata object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path mcp:_meta ] ;
    sh:targetClass mcp:ResourceContents .

mcp:SamplingCapability a sh:NodeShape ;
    rdfs:comment "Client sampling capability." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass mcp:SamplingCapability .

mcp:StructuredContentData a sh:NodeShape ;
    rdfs:comment "Structured content object returned by tools." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:float ;
            sh:description "Humidity percentage value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path mcp:humidity ],
        [ sh:datatype xsd:string ;
            sh:description "Weather conditions description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path mcp:conditions ],
        [ sh:datatype xsd:float ;
            sh:description "Sampling temperature." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path mcp:temperature ] ;
    sh:targetClass mcp:StructuredContentData .

mcp:Task a sh:NodeShape ;
    rdfs:comment "Data associated with a task." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Current task state." ;
            sh:in ( "cancelled" "completed" "failed" "input_required" "working" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path mcp:status ],
        [ sh:datatype xsd:string ;
            sh:description "ISO 8601 timestamp when the task was last updated." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path mcp:lastUpdatedAt ],
        [ sh:datatype xsd:integer ;
            sh:description "Actual retention duration from creation in milliseconds, null for unlimited." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path mcp:ttl ],
        [ sh:datatype xsd:integer ;
            sh:description "Suggested polling interval in milliseconds." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path mcp:pollInterval ],
        [ sh:datatype xsd:string ;
            sh:description "Optional human-readable message describing the current task state." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path mcp:statusMessage ],
        [ sh:datatype xsd:string ;
            sh:description "ISO 8601 timestamp when the task was created." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path mcp:createdAt ],
        [ sh:datatype xsd:string ;
            sh:description "The task identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path mcp:taskId ] ;
    sh:targetClass mcp:Task .

mcp:TasksCapability a sh:NodeShape ;
    rdfs:comment "Task capability object." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class mcp:TaskRequestCapabilities ;
            sh:description "Task request capabilities." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path mcp:requests ] ;
    sh:targetClass mcp:TasksCapability .

mcp:Tool a sh:NodeShape ;
    rdfs:comment "Definition for a tool the client can call." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class mcp:MetaObject ;
            sh:description "Optional metadata object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path mcp:_meta ],
        [ sh:datatype xsd:string ;
            sh:description "Intended for UI and end-user contexts — optimized to be human-readable and easily understood." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path dct:title ],
        [ sh:class mcp:JsonSchema ;
            sh:description "A JSON Schema object defining the expected parameters for the tool." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path mcp:inputSchema ],
        [ sh:class mcp:ToolExecution ;
            sh:description "Execution-related properties for this tool." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path mcp:execution ],
        [ sh:class mcp:Icon ;
            sh:description "Optional set of sized icons that the client can display in a user interface." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path mcp:icons ],
        [ sh:class mcp:JsonSchema ;
            sh:description "An optional JSON Schema object defining the structure of the tool's output." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path mcp:outputSchema ],
        [ sh:datatype xsd:string ;
            sh:description "Intended for programmatic or logical use, but used as a display name in past specs or fallback (if title is not present)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path schema1:name ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path dct:description ],
        [ sh:class mcp:ToolAnnotations ;
            sh:description "Optional additional tool information." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path mcp:annotations ] ;
    sh:targetClass mcp:Tool .

mcp:ToolsCapability a sh:NodeShape ;
    rdfs:comment "Server tools capability." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "Whether notifications for list changes are supported." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path mcp:listChanged ] ;
    sh:targetClass mcp:ToolsCapability .

mcp:ArgumentMap a sh:NodeShape ;
    rdfs:comment "Argument object used in prompt and tool calls." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Location value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path mcp:location ],
        [ sh:datatype xsd:string ;
            sh:description "City value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path mcp:city ],
        [ sh:datatype xsd:string ;
            sh:description "Programming language value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path mcp:language ],
        [ sh:datatype xsd:string ;
            sh:description "Framework value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path mcp:framework ] ;
    sh:targetClass mcp:ArgumentMap .

mcp:SchemaItems a sh:NodeShape ;
    rdfs:comment "JSON Schema items expression used by enum multi-select schemas." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class mcp:EnumOption ;
            sh:description "JSON Schema anyOf entries." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path mcp:anyOf ],
        [ sh:datatype xsd:string ;
            sh:description "Array of enum values." ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path mcp:enum ],
        [ sh:datatype xsd:string ;
            sh:description "Type discriminator field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path mcp:type ] ;
    sh:targetClass mcp:SchemaItems .

mcp:EnumOption a sh:NodeShape ;
    rdfs:comment "Single enumerated option with a machine value and display title." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Intended for UI and end-user contexts — optimized to be human-readable and easily understood." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path dct:title ],
        [ sh:datatype xsd:string ;
            sh:description "JSON Schema const value." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path mcp:const ] ;
    sh:targetClass mcp:EnumOption .

mcp:Result a sh:NodeShape ;
    rdfs:comment "Common result fields." ;
    sh:closed true ;
    sh:ignoredProperties ( mcp:prompts mcp:taskId mcp:resources mcp:protocolVersion mcp:tasks mcp:messages mcp:task mcp:lastUpdatedAt mcp:createdAt mcp:ttl mcp:tools mcp:structuredContent mcp:stopReason mcp:action mcp:serverInfo mcp:pollInterval mcp:isError mcp:statusMessage dct:description mcp:roots mcp:instructions mcp:capabilities mcp:status rdf:type mcp:resourceTemplates mcp:model mcp:content mcp:nextCursor mcp:role mcp:contents mcp:completion ) ;
    sh:property [ sh:class mcp:MetaObject ;
            sh:description "Optional metadata object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path mcp:_meta ] ;
    sh:targetClass mcp:Result .

mcp:TaskMetadata a sh:NodeShape ;
    rdfs:comment "Metadata for augmenting a request with task execution." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "Actual retention duration from creation in milliseconds, null for unlimited." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path mcp:ttl ] ;
    sh:targetClass mcp:TaskMetadata .

mcp:ErrorData a sh:NodeShape ;
    rdfs:comment "Structured JSON-RPC error data payload." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "An optional string describing the reason." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path mcp:reason ],
        [ sh:class mcp:URLElicitation ;
            sh:description "URL elicitation entries included in error data." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path mcp:elicitations ] ;
    sh:targetClass mcp:ErrorData .

mcp:ContentBlock a sh:NodeShape ;
    rdfs:comment "Structured text content block." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Text content." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path mcp:text ],
        [ sh:datatype xsd:string ;
            sh:description "Type discriminator field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path mcp:type ] ;
    sh:targetClass mcp:ContentBlock .

mcp:Icon a sh:NodeShape ;
    rdfs:comment "An optionally-sized icon that can be displayed in a user interface." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Optional array of strings specifying sizes (WxH format or \"any\")." ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path mcp:sizes ],
        [ sh:datatype xsd:string ;
            sh:description "The MIME type of a resource, if known." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path mcp:mimeType ],
        [ sh:description "Optional theme specifier for the icon." ;
            sh:in ( "dark" "light" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path mcp:theme ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A standard URI pointing to an icon resource." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path mcp:src ] ;
    sh:targetClass mcp:Icon .

mcp:Annotations a sh:NodeShape ;
    rdfs:comment "Optional annotations for the client. The client can use annotations to inform how objects are used or displayed." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Describes who the intended audience of this object or data is." ;
            sh:in ( "assistant" "user" ) ;
            sh:order 0 ;
            sh:path mcp:audience ],
        [ sh:datatype xsd:float ;
            sh:description "How important this data is for operating the server. 1 means most important (required), 0 means least important (optional)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path mcp:priority ],
        [ sh:datatype xsd:string ;
            sh:description "The moment the resource was last modified, as an ISO 8601 formatted string." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path mcp:lastModified ] ;
    sh:targetClass mcp:Annotations .

mcp:JsonSchema a sh:NodeShape ;
    rdfs:comment "Restricted JSON Schema object used in MCP payloads." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Type discriminator field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path mcp:type ],
        [ sh:class mcp:EnumOption ;
            sh:description "JSON Schema anyOf entries." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path mcp:anyOf ],
        [ sh:datatype xsd:integer ;
            sh:description "Maximum length constraint." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path mcp:maxLength ],
        [ sh:class mcp:SchemaItems ;
            sh:description "JSON Schema items definition." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path mcp:items ],
        [ sh:datatype xsd:integer ;
            sh:description "Minimum value constraint." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path mcp:minimum ],
        [ sh:datatype xsd:anyType ;
            sh:description "Default value for a schema field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path mcp:default ],
        [ sh:datatype xsd:string ;
            sh:description "JSON Schema required property list." ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path mcp:required_list ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path dct:description ],
        [ sh:class mcp:SchemaProperties ;
            sh:description "JSON Schema properties map." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path mcp:properties ],
        [ sh:datatype xsd:boolean ;
            sh:description "JSON Schema additionalProperties flag." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path mcp:additionalProperties ],
        [ sh:datatype xsd:string ;
            sh:description "Intended for UI and end-user contexts — optimized to be human-readable and easily understood." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path dct:title ],
        [ sh:datatype xsd:string ;
            sh:description "Array of enum values." ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path mcp:enum ],
        [ sh:datatype xsd:string ;
            sh:description "JSON Schema const value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path mcp:const ],
        [ sh:datatype xsd:string ;
            sh:description "Optional JSON Schema dialect identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path mcp:schemaUri ],
        [ sh:datatype xsd:integer ;
            sh:description "Minimum length constraint." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path mcp:minLength ],
        [ sh:datatype xsd:integer ;
            sh:description "Maximum value constraint." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path mcp:maximum ],
        [ sh:class mcp:EnumOption ;
            sh:description "JSON Schema oneOf entries." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path mcp:oneOf ],
        [ sh:description "String format constraint." ;
            sh:in ( "date" "date-time" "email" "uri" ) ;
            sh:maxCount 1 ;
            sh:order 9 ;
            sh:path mcp:format ] ;
    sh:targetClass mcp:JsonSchema .

mcp:MetaObject a sh:NodeShape ;
    rdfs:comment "Metadata object attached to protocol objects." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The progress token which was given in the initial request, used to associate this notification with the request that is proceeding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path mcp:progressToken ] ;
    sh:targetClass mcp:MetaObject .

