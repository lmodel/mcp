            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path mcp:id ],
        [ sh:class mcp:CancelTaskResult ;
            sh:description "JSON-RPC successful result payload." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path mcp:result ],
        [ sh:datatype xsd:string ;
            sh:description "JSON-RPC version string." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path mcp:jsonrpc ] ;
    sh:targetClass mcp:CancelTaskResultResponse .

mcp:CancelledNotification a sh:NodeShape ;
    rdfs:comment "Notification to indicate that a previously-issued request is being cancelled." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class mcp:CancelledNotificationParams ;
            sh:description "JSON-RPC parameters payload." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path mcp:params ],
        [ sh:datatype xsd:string ;
            sh:description "The JSON-RPC method name." ;
            sh:in ( "notifications/cancelled" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path mcp:method ],
        [ sh:datatype xsd:string ;
            sh:description "JSON-RPC version string." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path mcp:jsonrpc ] ;
    sh:targetClass mcp:CancelledNotification .

mcp:ClientNotification a sh:NodeShape ;
    rdfs:comment "A union of all notifications that can be sent by a client." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass mcp:ClientNotification .

mcp:ClientRequest a sh:NodeShape ;
    rdfs:comment "A union of all requests that can be sent by a client." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass mcp:ClientRequest .

mcp:ClientResult a sh:NodeShape ;
    rdfs:comment "A union of all result types that a client can return." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass mcp:ClientResult .

mcp:CompleteRequest a sh:NodeShape ;
    rdfs:comment "A request from the client to the server, to ask for completion options." ;
