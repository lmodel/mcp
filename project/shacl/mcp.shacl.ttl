        [ sh:class mcp:ElicitationCompleteNotificationParams ;
            sh:description "JSON-RPC parameters payload." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path mcp:params ] ;
    sh:targetClass mcp:ElicitationCompleteNotification .

