mcp:ElicitResult a sh:NodeShape ;
    rdfs:comment "The result returned by the client for an elicitation/create request." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class mcp:MetaObject ;
            sh:description "Optional metadata object." ;
